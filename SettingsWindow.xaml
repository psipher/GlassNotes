<Window x:Class="LucidNotes.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="400" 
        Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Topmost="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled"
        FontFamily="Segoe UI Variable Display, Segoe UI">
    <Window.Resources>
        <!-- Modern ComboBox ToggleButton -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" 
                        Grid.ColumnSpan="2"
                        CornerRadius="8"
                        Background="White"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1.5" />
                
                <TextBlock x:Name="Arrow"
                           Grid.Column="1"
                           Text="&#xE70D;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="11"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter TargetName="Border" Property="Background" Value="#F8F8F8" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#C8C8C8" />
                </Trigger>
                <Trigger Property="IsChecked" Value="true">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                    <Setter TargetName="Border" Property="Background" Value="#F8F8F8" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Modern ComboBox Style (Implicit) -->
        <Style TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E2E2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- ToggleButton fills the entire grid to capture clicks -->
                            <ToggleButton Name="ToggleButton" 
                                          Template="{StaticResource ComboBoxToggleButton}" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="14,0,44,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"                
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderThickness="1.5"
                                            BorderBrush="#E2E2E2"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Opacity="0.12"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6"
                                            Margin="4,2"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#F2F2F2"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#EBF4FF"/>
                                            <Setter Property="Foreground" Value="#0066CC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>



    <!-- Floating card with rounded corners and drop shadow -->
    <Border Background="#FFFFFFFF"
            CornerRadius="16"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="32"
                              ShadowDepth="6"
                              Opacity="0.22"
                              Direction="270"/>
        </Border.Effect>



        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Tab bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Header: "Settings" title + X close button, draggable -->
            <Grid Grid.Row="0"
                  Margin="20,16,12,0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="Settings"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111111"
                           VerticalAlignment="Center"/>
                <Button Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="32" Height="32"
                        Click="CloseButton_Click"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#666666"
                        Background="Transparent"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#F0F0F0"/>
                                                <Setter Property="Foreground" Value="#333333"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Tab Bar with underline indicator -->
            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tab Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0">
                    <!-- General Tab -->
                    <Button x:Name="TabGeneral"
                            Click="Tab_Click" Tag="General"
                            Margin="0,0,4,0"
                            FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Padding" Value="10,10"/>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Text="General" FontSize="14" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontWeight="{TemplateBinding FontWeight}"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Colors Tab -->
                    <Button x:Name="TabColors"
                            Click="Tab_Click" Tag="Colors"
                            Margin="4,0"
                            FontWeight="Normal">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Padding" Value="10,10"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Text="Colors" FontSize="14" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontWeight="{TemplateBinding FontWeight}"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Font Tab -->
                    <Button x:Name="TabFont"
                            Click="Tab_Click" Tag="Font"
                            Margin="4,0"
                            FontWeight="Normal">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Padding" Value="10,10"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Text="Font" FontSize="14" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontWeight="{TemplateBinding FontWeight}"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- About Tab -->
                    <Button x:Name="TabAbout"
                            Click="Tab_Click" Tag="About"
                            Margin="4,0"
                            FontWeight="Normal">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Padding" Value="10,10"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Text="About" FontSize="14" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontWeight="{TemplateBinding FontWeight}"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Underline indicators row -->
                <Grid Grid.Row="1" Margin="0,12,0,0" Height="1">
                    <Rectangle Fill="#E0E0E0"/>
                    <Rectangle x:Name="TabUnderline"
                               Fill="#FFD700"
                               RadiusX="2" RadiusY="2"
                               HorizontalAlignment="Left"
                               Height="3"
                               Width="70"
                               Margin="20,0,0,0"
                               VerticalAlignment="Bottom"/>                        
                </Grid>
            </Grid>

            <!-- Tab Content -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="24,24,24,24">
                <Grid>
                <!-- General Tab Content -->
                <StackPanel x:Name="PanelGeneral">
                    <TextBlock Text="Transparency:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,10"/>
                    <Slider x:Name="TransparencySlider"
                            Minimum="0.3"
                            Maximum="1.0"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,6"
                            Style="{StaticResource ModernSlider}"/>
                    <TextBlock x:Name="TransparencyLabel"
                               Text="77%"
                               Foreground="#888888"
                               FontSize="12"
                               Margin="0,0,0,20"/>

                    <CheckBox x:Name="AlwaysOnTopCheckBox"
                              Content="Always on top"
                              Foreground="#1A1A1A"
                              FontSize="14"
                              Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Colors Tab Content -->
                <StackPanel x:Name="PanelColors" Visibility="Collapsed">
                    <TextBlock Text="Background Color:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="BackgroundColorComboBox"
                              Margin="0,0,0,20">
                        <ComboBoxItem Content="Cream" Tag="Cream"/>
                        <ComboBoxItem Content="White" Tag="White"/>
                        <ComboBoxItem Content="Black" Tag="Black"/>
                        <ComboBoxItem Content="Light Gray" Tag="Light Gray"/>
                        <ComboBoxItem Content="Light Blue" Tag="Light Blue"/>
                        <ComboBoxItem Content="Light Green" Tag="Light Green"/>
                        <ComboBoxItem Content="Light Pink" Tag="Light Pink"/>
                    </ComboBox>

                    <TextBlock Text="Text Color:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="TextColorComboBox"
                              Margin="0,0,0,20">
                        <ComboBoxItem Content="Black" Tag="Black"/>
                        <ComboBoxItem Content="Dark Gray" Tag="Dark Gray"/>
                        <ComboBoxItem Content="Gray" Tag="Gray"/>
                        <ComboBoxItem Content="White" Tag="White"/>
                        <ComboBoxItem Content="Dark Blue" Tag="Dark Blue"/>
                        <ComboBoxItem Content="Dark Green" Tag="Dark Green"/>
                        <ComboBoxItem Content="Dark Red" Tag="Dark Red"/>
                        <ComboBoxItem Content="Purple" Tag="Purple"/>
                    </ComboBox>
                </StackPanel>

                <!-- Font Tab Content -->
                <StackPanel x:Name="PanelFont" Visibility="Collapsed">
                    <TextBlock Text="Font:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,10"/>
                    <ComboBox x:Name="FontFamilyComboBox"
                              Margin="0,0,0,20">
                        <ComboBoxItem Content="Segoe UI" Tag="Segoe UI"/>
                        <ComboBoxItem Content="Arial" Tag="Arial"/>
                        <ComboBoxItem Content="Calibri" Tag="Calibri"/>
                        <ComboBoxItem Content="Consolas" Tag="Consolas"/>
                        <ComboBoxItem Content="Georgia" Tag="Georgia"/>
                        <ComboBoxItem Content="Times New Roman" Tag="Times New Roman"/>
                        <ComboBoxItem Content="Verdana" Tag="Verdana"/>
                    </ComboBox>

                    <TextBlock Text="Font Size:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,10"/>
                    <Slider x:Name="FontSizeSlider"
                            Minimum="10"
                            Maximum="24"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,8"
                            Style="{StaticResource ModernSlider}"/>
                    <TextBlock x:Name="FontSizeLabel"
                               Text="14px"
                               Foreground="#888888"
                               FontSize="12"
                               Margin="0,0,0,0"/>
                </StackPanel>

                <!-- About Tab Content -->
                <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                    <TextBlock Text="Lucid Notes"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1A1A1A"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Version 2.0"
                               Foreground="#888888"
                               FontSize="13"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="A modern, lightweight note-taking application for Windows 10/11 with transparent overlay features."
                               TextWrapping="Wrap"
                               Foreground="#444444"
                               FontSize="13"
                               LineHeight="20"/>
                </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
